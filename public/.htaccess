# Apache configuration for the Front Controller pattern.
# This redirects all requests for non-existent files to index.php.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Do not apply to files/directories that exist.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirect all other requests to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

